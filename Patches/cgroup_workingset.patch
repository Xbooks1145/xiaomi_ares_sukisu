+        SECURE_STRCPY_BY_STRUCT(30)\
+        SECURE_STRCPY_BY_STRUCT(31)\
+        SECURE_STRCPY_BY_STRUCT(32)\
+        }/*END switch*/ \
+    } \
+    else \
+    { \
+        char* pcDest = (char*)strDest; \
+        char* pcSrc =  (char*)strSrc; \
+        switch(srcStrLen) \
+        { /*lint -save -e616*/\
+        SECURE_STRCPY_BY_BYTE(32)\
+        SECURE_STRCPY_BY_BYTE(31)\
+        SECURE_STRCPY_BY_BYTE(30)\
