+#define __SECUREC_H__5D13A042_DC3F_4ED9_A8D1_882811274C27
+
+/* If you need high performance, enable the WITH_PERFORMANCE_ADDONS macro! */
+#if !defined(__LPMCU__) && !defined(__UCE_SEC_LIB__)
