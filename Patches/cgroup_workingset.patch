+    (void)sscanf_s( tokenstring, "%80s", s, 81 ); 
+    (void)sscanf_s( tokenstring, "%c", &c, 1 );  
+    (void)sscanf_s( tokenstring, "%d", &i );  
+    (void)sscanf_s( tokenstring, "%f", &fp ); 
