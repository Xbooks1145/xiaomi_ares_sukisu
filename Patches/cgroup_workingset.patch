+            (void)memset_opt(dest, c, count);
+#else
+            (void)memset(dest, c, count);
+#endif
+            return EOK;
+#if defined(SECUREC_MEMSET_WITH_PERFORMANCE)
+        }
+        else
+        {
+            if (SC_ADDR_ALIGNED(dest) )
+            {
