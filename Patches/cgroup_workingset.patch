+
+        iRet =fwscanf_s(stream, L"%ls", wString, sizeof(wString)/sizeof(wchar_t));
+        wprintf(L"iRet = %d, %ls\n", iRet, wString);
+
+        fclose(stream);
+    }
+    return 0;
+}
