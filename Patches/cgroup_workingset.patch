+extern "C" {
+#endif
+    int SecVsnprintfImpl(char *string, size_t count, const char *format, va_list argList);
+#ifdef SECUREC_FOR_WCHAR
+    int SecVswprintfImpl(wchar_t *string, size_t sizeInWchar, const wchar_t *format, va_list argList);
+#endif
