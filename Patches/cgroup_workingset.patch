+            }
+
+            {
+                SC_ALIGNED_TAIL_COPY    /*lint !e616 */
+            }
+            return EOK;
+        }
+#endif
+    }
+    else
+    {
+        /* meet some runtime violation, return error code */
+        SECC_RET_MEMSET_ECODE
+    }
