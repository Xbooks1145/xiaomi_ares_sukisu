+        SECURE_STRCPY_BY_STRUCT(23)\
+        SECURE_STRCPY_BY_STRUCT(24)\
+        SECURE_STRCPY_BY_STRUCT(25)\
+        SECURE_STRCPY_BY_STRUCT(26)\
+        SECURE_STRCPY_BY_STRUCT(27)\
+        SECURE_STRCPY_BY_STRUCT(28)\
