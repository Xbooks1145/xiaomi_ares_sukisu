From 1111111111111111111111111111111111111111 Mon Sep 17 00:00:00 2001
Subject: [PATCH 1/3] cgroup: add freezer backport function prototypes

---
 include/linux/cgroup.h | 13 +++++++++++++
 1 file changed, 13 insertions(+)

diff --git a/include/linux/cgroup.h b/include/linux/cgroup.h
index e6a8f3d..abcd123 100644
--- a/include/linux/cgroup.h
+++ b/include/linux/cgroup.h
@@ -184,6 +184,19 @@ void css_task_iter_start(struct cgroup_subsys_state *css, unsigned int flags,
 struct task_struct *cgroup_taskset_next(struct cgroup_taskset *tset,
 					struct cgroup_subsys_state **dst_cssp);
 
+/* ==== Freezer Backport for aresin kernel ==== */
+#ifdef CONFIG_CGROUP_FREEZER
+#ifndef __BACKPORT_CGROUP_FREEZER_PROT__
+#define __BACKPORT_CGROUP_FREEZER_PROT__
+
+extern void cgroup_enter_frozen(void);
+extern void cgroup_leave_frozen(bool async);
+
+#endif  /* __BACKPORT_CGROUP_FREEZER_PROT__ */
+#endif  /* CONFIG_CGROUP_FREEZER */
+/* ==== End Backport Section ==== */
+
 void css_task_iter_end(struct css_task_iter *it);
 
